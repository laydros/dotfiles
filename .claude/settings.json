{
  "env": {
    "OBNOTES_PATH": "$HOME/Documents/obnotes"
  },
  "permissions": {
    "allow": [
      "Bash($HOME/.claude/skills/z3-dev-server/scripts/restart.sh)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/laydros/.local/share/uv/tools/nah/bin/python /Users/laydros/.claude/hooks/nah_guard.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/laydros/.local/share/uv/tools/nah/bin/python /Users/laydros/.claude/hooks/nah_guard.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/laydros/.local/share/uv/tools/nah/bin/python /Users/laydros/.claude/hooks/nah_guard.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/laydros/.local/share/uv/tools/nah/bin/python /Users/laydros/.claude/hooks/nah_guard.py"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/laydros/.local/share/uv/tools/nah/bin/python /Users/laydros/.claude/hooks/nah_guard.py"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/laydros/.local/share/uv/tools/nah/bin/python /Users/laydros/.claude/hooks/nah_guard.py"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/laydros/.local/share/uv/tools/nah/bin/python /Users/laydros/.claude/hooks/nah_guard.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "playground@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "effortLevel": "high"
}
